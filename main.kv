<InfoPanel>:
    orientation: "vertical"
    size_hint: None, None
    padding: 20
    spacing: 10
    canvas.before:
        Color:
            rgba: 0,0,0,0.7
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [15,]
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 15)
            width: 2
    Label:
        id: title_label
        text: "Informacion del Evento"
        font_name: 'BebasNeue'
        font_size: '48sp'
        size_hint_y: None
        height: 50
        color: 1,1,1,1
        text_size: self.width, None
        halign: 'center'
    BoxLayout:
        size_hint_y: None
        height: 20
    Label:
        id: desc_label
        text: "Pasa el mouse sobre un evento para ver detalles"
        font_name: 'OpenSans'
        font_size: '16sp'
        markup: True
        text_size: self.width, None
        halign: 'center'
        valign: 'top'
        size_hint_y: None
        height: 200
        color: 1,1,1,1
    Label:
        id: req_label
        text: ""
        font_name: 'OpenSans'
        font_size: '12sp'
        text_size: self.width, None
        halign: 'center'
        valign: 'top'
        size_hint_y: None
        height: 100
        color: 1,0.8,0.8,1
<selection_matrix>:
    size_hint: None, None
    size: 500, 650
    pos: 800, 0
    canvas.before:
        Color:
            rgba: 0,0,0,0.6
        RoundedRectangle:
            pos: self.pos[0], self.pos[1]
            size: self.size
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 15)
            width: 2
<bottom_button>:
    size_hint: None, None
    size: 200, 100
    pos: 550, -90
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            rounded_rectangle: (self.x, self.y+4, self.width, self.height-10, 15)
            width: 2