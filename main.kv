<Main_Container>:
    canvas.before:
        Color:
            rgba: 0,0,0,0
        Rectangle:
            pos: self.pos
            size: self.size
<classic_button>:
    size_hint: None, None
    width: 200
    pos_hint: {"center_x": 0.5, "center_y":0.5}
    height: 100
    text: "b"
    font_size: 24
<change_button>:
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            rounded_rectangle: (self.x, self.y+4, self.width, self.height-10, 15)
            width: 2
<volver_button>:
    size_hint: None, None
    size: 200, 100
    pos: 20, 10
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            rounded_rectangle: (self.x, self.y+4, self.width, self.height-10, 15)
            width: 2
<sound_button>:
    size_hint: None, None
    height: 50
    width: 50
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            circle: (self.center_x, self.center_y, min(self.width, self.height) / 2 +10)
            width: 2
<main_button_container>:
    orientation: "vertical"
    size_hint: None, None
    width: 240
    height: 550
    spacing: 30
    canvas.before:
        Color:
            rgba: 0,0,0,0.6
        RoundedRectangle:
            pos: self.pos[0]-20, self.pos[1]-30
            size: self.size
    canvas.after:
        Color:
            rgba: 1,1,1,1
        Line:
            rounded_rectangle: (self.pos[0]-20, self.pos[1]-30, self.width, self.height, 15)
            width: 2
